# Desativa a listagem de arquivos das pastas para maior segurança
Options -Indexes

# Configuração amigável de roteamento Apache
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Como a calculadora está em uma subpasta e não possui rotas React Router no navegador
  # (apenas controle de estado interno), removemos a regra de redirecionamento global RewriteRule / index.html
  # para que ela não cause erros de pasta física nem conflite com outras subpastas.
</IfModule>
